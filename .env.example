PORT=8080
NODE_ENV=development
# Public site URL (no trailing slash) for Open Graph og:url / og:image absolute URLs.
# If empty, the server derives https://host from each request (set this in production).
PUBLIC_SITE_URL=
# Set true behind reverse proxy/load balancer in production (for secure cookies)
TRUST_PROXY=false
# Toggle homepage lead form source.
# false = use local MR OK form (/api/leads)
# true  = use embedded DSA public website form
USE_DSA_PUBLIC_FORM=false
# Optional: Google Apps Script Web App URL for lead forwarding
GOOGLE_SCRIPT_URL=
# Required for admin leads endpoint authentication
ADMIN_API_KEY=
# Optional admin login page credentials (/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Required in production for stateless admin cookie sessions (min 32 chars)
ADMIN_SESSION_SECRET=

# Optional SMTP email notifications for new lead form submissions
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
LEAD_NOTIFICATION_TO=mrokfinance@gmail.com

# Optional: DSA Sathi CRM — auto-push each new lead (Bearer token from Settings → API Integration)
# Production: https://api.dsasathi.com/v1   Sandbox: https://sandbox.dsasathi.com/v1
DSASATHI_API_BASE_URL=https://api.dsasathi.com/v1
DSASATHI_API_KEY=
# Optional: default source tag sent to DSA (e.g. website, whatsapp, facebook)
DSASATHI_SOURCE=website
# Optional: fixed DSA agent id if your account requires it
DSASATHI_ASSIGNED_TO=

# Inbound webhooks (Settings → Webhooks in DSA Sathi). Use either URL on this server:
#   https://YOUR_HOST/api/webhooks/dsasathi   or   https://YOUR_HOST/dsa-webhook
# Raw JSON body + optional HMAC (header X-DSA-Signature, hex SHA-256 of body).
DSASATHI_WEBHOOK_SECRET=
# Optional: comma-separated allowlist (e.g. 54.169.123.45). Empty = do not check client IP.
DSASATHI_WEBHOOK_ALLOW_IPS=

# AI calling pipeline (consent-driven)
AI_CALL_ENABLED=true
# mock = built-in simulated caller, twilio = external provider integration mode
AI_CALL_PROVIDER=mock
# Cooldown between call attempts for same lead
AI_CALL_COOLDOWN_HOURS=12
# Worker polling interval for queued AI call jobs (milliseconds)
AI_CALL_WORKER_INTERVAL_MS=15000
# Eligible states for AI calling (case-insensitive, comma separated)
AI_CALL_ELIGIBLE_STATES=haryana,delhi,uttar pradesh

# Twilio outbound calling (required when AI_CALL_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Public HTTPS base URL used by Twilio callbacks (e.g. https://yourdomain.com)
TWILIO_CALLBACK_BASE_URL=
# Keep true in production
TWILIO_VALIDATE_SIGNATURE=true

# Google Calendar booking (optional; used when appointment_status=booked)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste private key with escaped newlines (\\n)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
